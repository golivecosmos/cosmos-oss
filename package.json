{
  "name": "cosmos-oss",
  "private": false,
  "version": "0.1.4",
  "description": "Cosmos OSS desktop app for local-first multimodal search",
  "license": "MIT",
  "repository": "https://github.com/cosmos-oss/cosmos-oss",
  "type": "module",
  "scripts": {
    "dev": "tauri dev --features dev-tools",
    "dev:scan": "VITE_REACT_SCAN=true tauri dev --features dev-tools",
    "dev:web": "vite",
    "bootstrap:assets": "node scripts/bootstrap-assets.mjs",
    "bootstrap:assets:force": "node scripts/bootstrap-assets.mjs --force",
    "bootstrap:assets:models": "node scripts/bootstrap-assets.mjs --skip-ffmpeg",
    "bootstrap:assets:ffmpeg": "node scripts/bootstrap-assets.mjs --skip-models",
    "release:audit": "node scripts/release-security-audit.mjs",
    "release:production": "node scripts/release.mjs",
    "release:production:upload": "node scripts/release.mjs --upload",
    "release:build-and-notarize": "bash scripts/build-and-notarize.sh",
    "typecheck": "tsc --noEmit",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:desktop": "pnpm run build && tauri build",
    "test:backend": "cd src-tauri && cargo test",
    "lint": "pnpm run typecheck",
    "postinstall": "node scripts/bootstrap-assets.mjs --optional"
  },
  "dependencies": {
    "@radix-ui/react-context-menu": "^2.2.6",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tanstack/react-virtual": "^3.13.4",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.1",
    "framer-motion": "^11.17.0",
    "install": "^0.13.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.469.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.1.1",
    "sonner": "^2.0.6",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/lodash": "^4.17.14",
    "@types/node": "^20.17.11",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "autoprefixer": "^10.4.20",
    "cli": "^1.0.1",
    "postcss": "^8.4.49",
    "react-scan": "^0.4.3",
    "shadcn-ui": "^0.9.4",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "terser": "^5.40.0",
    "typescript": "^5.0.2",
    "vite": "^4.4.4"
  }
}
