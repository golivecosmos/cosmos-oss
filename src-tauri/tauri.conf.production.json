{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Cosmos OSS",
  "version": "0.1.0",
  "identifier": "com.cosmos.oss",
  "build": {
    "beforeDevCommand": "vite",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      },
      "capabilities": [
        "main-capability"
      ]
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "Cosmos",
        "width": 1200,
        "minWidth": 800,
        "minHeight": 800
      }
    ],
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": null,
      "frameworks": [],
      "entitlements": "entitlements.plist",
      "exceptionDomain": "",
      "minimumSystemVersion": "10.13"
    },
    "icon": [
      "icons/icon_32x32.png",
      "icons/icon_128x128.png",
      "icons/icon_128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "",
    "category": "Productivity",
    "shortDescription": "A desktop application for managing and searching documents",
    "longDescription": "Cosmos helps users organize, search, and manage their digital documents and images using advanced vector search capabilities."
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": ""
    }
  }
}
